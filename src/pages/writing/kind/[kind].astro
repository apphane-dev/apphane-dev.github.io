---
import Base from '../../../layouts/Base.astro';
import SiteHeader from '../../../components/site/SiteHeader.astro';
import SiteFooter from '../../../components/site/SiteFooter.astro';
import WritingCard from '../../../components/writing/WritingCard.astro';
import { getPublishedWriting } from '../../../lib/writing';
import { kinds, KIND_IDS, type Kind } from '../../../data/topics';

export async function getStaticPaths() {
  return KIND_IDS.map((kind) => ({ params: { kind } }));
}

const { kind } = Astro.params as { kind: Kind };
const info = kinds[kind];
const entries = (await getPublishedWriting()).filter((e) => e.data.kind === kind);
---

<Base title={`${info.plural} — apphane writing`} description={info.blurb}>
  <a class="skip" href="#main">Skip to content</a>
  <SiteHeader />
  <main id="main" class="page">
    <div class="page-head">
      <p class="eyebrow">Writing / {info.plural}</p>
      <h1>{info.plural}</h1>
      <p class="lede">{info.blurb}</p>
    </div>
    <section class="writing-list" aria-label={`All ${info.plural.toLowerCase()}`}>
      {entries.map((entry) => <WritingCard entry={entry} />)}
      {entries.length === 0 && <p class="empty">No {info.plural.toLowerCase()} yet.</p>}
    </section>
    <p class="all"><a href="/writing/">← All writing</a></p>
  </main>
  <SiteFooter />
</Base>

<style>
  .empty {
    color: var(--cream-dim);
    padding: 2rem 0;
  }
  .all {
    margin-top: 2rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
  }
</style>
