---
import '@fontsource/baloo-2/600.css';
import '@fontsource/baloo-2/700.css';
import '@fontsource/ibm-plex-sans/400.css';
import '@fontsource/ibm-plex-sans/500.css';
import '@fontsource/ibm-plex-mono/400.css';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  /** 'article' switches Open Graph and enables the dates below. */
  ogType?: 'website' | 'article';
  publishedAt?: Date;
  updatedAt?: Date;
}

const { title, description, ogType = 'website', publishedAt, updatedAt } = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('apphane-logo.png', Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="apphane — writing"
      href={new URL('rss.xml', Astro.site)}
    />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    {publishedAt && (
      <meta property="article:published_time" content={publishedAt.toISOString()} />
    )}
    {updatedAt && (
      <meta property="article:modified_time" content={updatedAt.toISOString()} />
    )}
    <meta name="twitter:card" content="summary" />
    <meta name="theme-color" content="#00030C" />
  </head>
  <body>
    <slot />
  </body>
</html>
