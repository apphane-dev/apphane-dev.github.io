---
import { projects, HOUSE_WINDOWS } from '../data/projects';

/**
 * The signature element: a row of house windows, one per project slot.
 * A lit window is a shipped project (linked to its card); dark windows
 * are rooms still being furnished.
 */
const windows = Array.from({ length: HOUSE_WINDOWS }, (_, i) => projects[i] ?? null);
const projectCount = projects.length;
const caption = `${projectCount === 1 ? 'One light is' : `${projectCount} lights are`} on. More rooms are being furnished.`;
---

<div class="strip" role="list" aria-label="Projects in the house">
  {
    windows.map((project, i) =>
      project ? (
        <a
          role="listitem"
          class="window lit"
          href={`#${project.id}`}
          aria-label={`${project.name} — ${project.tagline}`}
          style={`--delay: ${i * 90}ms`}
        >
          <span class="panes" aria-hidden="true">
            <i /><i /><i /><i />
          </span>
          <span class="label">{project.name}</span>
        </a>
      ) : (
        <span role="listitem" class="window dark" aria-label="Room being furnished" style={`--delay: ${i * 90}ms`}>
          <span class="panes" aria-hidden="true">
            <i /><i /><i /><i />
          </span>
        </span>
      ),
    )
  }
</div>
<p class="strip-caption">{caption}</p>

<style>
  .strip {
    display: flex;
    justify-content: center;
    column-gap: 1.1rem;
    /* Labels are absolutely positioned below each window, so wrapped rows
       need extra vertical room to clear the previous row's labels. */
    row-gap: 2.4rem;
    flex-wrap: wrap;
  }

  .window {
    position: relative;
    width: 3.25rem;
    height: 3.25rem;
    border-radius: 0.55rem;
    border: 1.5px solid var(--cream-faint);
    display: grid;
    place-items: center;
    animation: settle 0.5s ease-out both;
    animation-delay: var(--delay);
  }

  .panes {
    display: grid;
    grid-template-columns: repeat(2, 0.85rem);
    grid-template-rows: repeat(2, 0.85rem);
    gap: 0.3rem;
  }

  .panes i {
    border-radius: 0.2rem;
    background: rgba(252, 237, 210, 0.07);
  }

  .window.lit {
    border-color: var(--amber);
    box-shadow: 0 0 22px var(--glow);
  }

  .window.lit .panes i {
    background: var(--amber);
    animation: light-on 0.45s ease-out both;
  }

  .window.lit .panes i:nth-child(2) {
    animation-delay: 0.55s;
  }
  .window.lit .panes i:nth-child(3) {
    animation-delay: 0.7s;
  }
  .window.lit .panes i:nth-child(4) {
    animation-delay: 0.85s;
  }

  .window.lit:hover {
    box-shadow: 0 0 34px var(--glow);
  }

  .label {
    position: absolute;
    top: calc(100% + 0.45rem);
    left: 50%;
    translate: -50% 0;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--amber);
    letter-spacing: 0.04em;
  }

  .strip-caption {
    margin-top: 2.6rem;
    text-align: center;
    font-size: 0.9375rem;
    color: var(--cream-dim);
  }

  @keyframes light-on {
    from {
      background: rgba(252, 237, 210, 0.07);
    }
    to {
      background: var(--amber);
    }
  }

  @keyframes settle {
    from {
      opacity: 0;
      translate: 0 6px;
    }
    to {
      opacity: 1;
      translate: 0 0;
    }
  }
</style>
