---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="card" id={project.id}>
  <header class="card-head">
    <h3 class="card-name">
      <span class="brace" aria-hidden="true">&#123;</span>
      {project.name}
      <span class="brace" aria-hidden="true">&#125;</span>
    </h3>
    <p class="gloss">
      <span lang="tr">{project.turkish.word}</span> — Turkish for <em>{project.turkish.meaning}</em>
    </p>
  </header>

  <p class="tagline">{project.tagline}</p>
  <p class="desc">{project.description}</p>

  <ul class="features">
    {project.features.map((feature) => <li>{feature}</li>)}
  </ul>

  {
    project.install && (
      <p class="install">
        <span class="install-label">{project.install.label}</span>
        <code>{project.install.command}</code>
      </p>
    )
  }

  <footer class="card-foot">
    <span class="meta">{project.license}</span>
    <span class="meta">{project.language}</span>
    <span class="meta">{project.platform}</span>
    <span class="spacer" aria-hidden="true"></span>
    {
      project.home && (
        <a class="link home-link" href={project.home}>
          Visit {project.name} ↗
        </a>
      )
    }
    {
      project.links.map((link) => (
        <a class="link" href={link.href}>
          {link.label} ↗
        </a>
      ))
    }
  </footer>
</article>

<style>
  .card {
    background: var(--ink-raised);
    border: 1px solid var(--cream-faint);
    border-radius: 1.1rem;
    padding: 2.2rem 2.4rem;
    scroll-margin-top: 3rem;
  }

  .card-head {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .card-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 2rem;
    line-height: 1.2;
  }

  .brace {
    color: var(--amber);
    font-weight: 600;
  }

  .gloss {
    font-size: 0.9375rem;
    color: var(--cream-dim);
  }

  .tagline {
    margin-top: 0.9rem;
    font-size: 1.15rem;
    font-weight: 500;
  }

  .desc {
    margin-top: 0.6rem;
    color: var(--cream-dim);
    max-width: var(--measure);
  }

  .features {
    margin-top: 1.4rem;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .features li {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--cream);
    border: 1px solid var(--cream-faint);
    border-radius: 999px;
    padding: 0.25rem 0.75rem;
  }

  .install {
    margin-top: 1.6rem;
    display: flex;
    align-items: baseline;
    gap: 0.9rem;
    flex-wrap: wrap;
  }

  .install-label {
    font-size: 0.9375rem;
    color: var(--cream-dim);
  }

  .install code {
    background: var(--ink);
    border: 1px solid var(--cream-faint);
    border-radius: 0.5rem;
    padding: 0.45rem 0.85rem;
    color: var(--amber);
  }

  .card-foot {
    margin-top: 1.8rem;
    padding-top: 1.3rem;
    border-top: 1px solid var(--cream-faint);
    display: flex;
    align-items: baseline;
    gap: 1.1rem;
    flex-wrap: wrap;
  }

  .meta {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--cream-dim);
  }

  .spacer {
    flex: 1;
  }

  .link {
    font-weight: 500;
    font-size: 0.9375rem;
  }

  .home-link {
    font-weight: 700;
  }

  @media (max-width: 40rem) {
    .card {
      padding: 1.5rem 1.3rem;
    }
  }
</style>
